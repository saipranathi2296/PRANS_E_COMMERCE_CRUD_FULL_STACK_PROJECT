{
  "name": "fullstack-backend",
  "version": "1.0.0",
  "description": "Backend API for Users, Products, and Orders using Node.js, Express, and MongoDB.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "start:all": "concurrently \"npm run dev\" \"npm --prefix client start\""
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.5.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  }
}
